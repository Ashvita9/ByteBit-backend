[Unit]
Description=ByteBit Backend (Daphne ASGI)
After=network.target

[Service]
Type=simple
User=ashvitakoli
Group=ashvitakoli
WorkingDirectory=/var/www/ByteBit-backend

# Load all env vars from the secrets file
EnvironmentFile=/var/www/ByteBit-backend/.env

ExecStart=/var/www/ByteBit-backend/venv/bin/daphne \
    -b 127.0.0.1 \
    -p 8000 \
    --access-log - \
    backend.asgi:application

Restart=on-failure
RestartSec=5
KillMode=mixed
TimeoutStopSec=10

StandardOutput=journal
StandardError=journal
SyslogIdentifier=bytebit-backend

[Install]
WantedBy=multi-user.target
