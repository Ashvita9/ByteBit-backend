DJANGO_SECRET_KEY=replace-this-with-a-long-random-string-50-chars
DJANGO_SETTINGS_MODULE=backend.settings

# Must be False in production
DEBUG=False

# Comma-separated list of allowed hostnames/IPs
ALLOWED_HOSTS=35.200.152.58,localhost,127.0.0.1

# ── CORS / CSRF ───────────────────────────────────────────────────────────────
# Add your production frontend URL here (Vercel domain or custom domain)
CORS_ALLOWED_ORIGINS=https://byte-bit-frontend.vercel.app,http://localhost:5173

# Origins added to CSRF_TRUSTED_ORIGINS on top of the hard-coded list in settings.py
# CSRF_TRUSTED_ORIGINS=

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Full Atlas connection string — include username, password, cluster, and db
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/bytebit_db?retryWrites=true&w=majority&appName=yourapp

# ── Redis (local on this VM) ──────────────────────────────────────────────────
# Leave as-is if Redis is running locally on default port
REDIS_URL=redis://127.0.0.1:6379/1

# ── (Optional) Sentry error tracking ─────────────────────────────────────────
# SENTRY_DSN=https://xxxx@oXXX.ingest.sentry.io/XXXX
